@page "/usuarios/crear"
@rendermode InteractiveServer

@using ProgramacionIII.Servicio.ServiciosHttp
@using ProgramacionIII.Shared.DTO_Response
@using ProgramacionIII.Shared.DTO_Roles
@using ProgramacionIII.Shared.DTO_Usuarios
@inject IHttpServicio http
@inject NavigationManager httpNav

<AuthorizeView Roles="Administrador">
    <Authorized>
        <h3>Crear usuario</h3>
        <EditForm Model="usuario" OnValidSubmit="Guardar" FormName="formularioCrearUsuario" Context="createContext">
            <DataAnnotationsValidator/>
            @if (!string.IsNullOrEmpty(MensajeError))
            {
                <p class="alert alert-danger">@MensajeError</p>
            }
            <div class="form-group container-fluid">
                <div class="my-3">
                    <label>Escriba el nombre de usuario:</label>
                    <div>
                        <InputText class="form-control" @bind-Value="usuario.NombreUsuario"/>
                        <ValidationMessage For="@(() => usuario.NombreUsuario)"/>
                    </div>
                </div>
                <div class="my-3">
                    <label>Escriba la contraseña del usuario:</label>
                    <div>
                        <InputText class="form-control" @bind-Value="usuario.Contrasena"/>
                        <ValidationMessage For="@(() => usuario.Contrasena)"/>
                    </div>
                </div>
                <div class="my-3">
                    <label>Escoja el rol del usuario:</label>
                    <div>
                        @if (roles != null)
                        {
                            <InputSelect class="form-select" @bind-Value="RolSeleccionado">
                                @foreach (var rol in roles)
                                {
                                    <option value="@rol.NombreRol">@FormatearTexto(rol.NombreRol)</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => usuario.Roles)"/>
                        }
                        else
                        {
                            <p>Hubo un error al cargar los roles desde el servidor. Reintente más tarde o contacte con
                                un administrador.</p>
                        }
                    </div>
                </div>
            </div>
            <button class="btn btn-success" type="submit">Guardar</button>
            <a class="btn btn-danger" href="/usuarios">Cancelar</a>
        </EditForm>
    </Authorized>
    <NotAuthorized>
        <h3>Usted no está autorizado a acceder a esta opción.</h3>
    </NotAuthorized>
</AuthorizeView>

@code {
    private UsuarioCrearDTO usuario = new UsuarioCrearDTO();
    private List<VerRolDTO> roles;

    private string RolSeleccionado
    {
        get => usuario.Roles?.FirstOrDefault() ?? "";
        set => usuario.Roles = new List<string> { value };
    }

    private string MensajeError;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await CargarRoles();
    }

    private async Task CargarRoles()
    {
        var res = await http.Get<Response<List<VerRolDTO>>>("api/roles");
        if (res.Respuesta != null)
        {
            roles = res.Respuesta.Objeto;
            RolSeleccionado = roles[0].NombreRol;
        }
    }

    private string FormatearTexto(string texto)
    {
        if (string.IsNullOrWhiteSpace(texto))
            return texto;

        return char.ToUpper(texto[0]) + texto.Substring(1).ToLower();
    }

    private async Task Guardar()
    {
        var res = await http.Post<UsuarioCrearDTO, Response<UsuarioVerDTO>>("api/usuarios", usuario);
        if (res.Respuesta != null)
        {
            if (res.Respuesta.Estado)
            {
                httpNav.NavigateTo("/usuarios");
            }
            else
            {
                MensajeError = res.Respuesta.Mensaje;
            }
        }
    }

}